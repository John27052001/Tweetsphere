datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  username     String
  passwordHash String
  createdAt    DateTime @default(now())

  tweets Tweet[]
}

model Tweet {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())

  authorId Int
  author   User     @relation(fields: [authorId], references: [id])
}
